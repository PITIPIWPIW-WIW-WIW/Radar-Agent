MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL_NAME=mistral-small-latest

DUPLICATE_THRESHOLD=0.59
VECTOR_DIM=384

LOG_LEVEL=INFO
LOG_FILE=app.log
ERROR_LOG_FILE=errors.log

# Путь к файлу sqlite. По умолчанию app_database.db в текущей папке —
# для Docker переопределяется на /app/data/app_database.db (см. docker-compose.yml)
DB_NAME=app_database.db

KAGGLE_USERNAME=your_kaggle_username_here
KAGGLE_KEY=your_kaggle_api_key_here

HUGGINGFACE_API_KEY=your_huggingface_token_here

# Путь к локально склонированному https://github.com/kukapay/hf-trending-mcp
# (git clone + pip install mcp[cli] httpx) — нужен для mcp_fetcher_hf_trending.py
HF_TRENDING_MCP_PATH=/absolute/path/to/hf-trending-mcp

GITHUB_TOKEN=your_github_token_here